import asyncio
from mcp.client.sse import sse_client
from mcp import ClientSession
import httpx

# All clients point to the same running server instance
SERVER_URL = "https://localhost:8000/sse"


def custom_httpx_factory(headers=None, timeout=None, auth=None):
    return httpx.AsyncClient(
        verify=False, # Disable SSL verification
        headers=headers, 
        timeout=timeout, 
        auth=auth
    )
    
async def run_client(client_id: str, state: str, latitude: float, longitude: float):
    """A single client that connects to the shared weather MCP server."""
    print(f"\n[Client {client_id}] Connecting to {SERVER_URL}...")

    async with sse_client(SERVER_URL, httpx_client_factory=custom_httpx_factory) as (read, write):
        async with ClientSession(read, write) as session:
            await session.initialize()

            tools = await session.list_tools()
            print(f"[Client {client_id}] Available tools: {[t.name for t in tools.tools]}")

            # Get alerts
            result = await session.call_tool("get_alerts", arguments={"state": state})
            print(f"[Client {client_id}] Alerts for {state}:\n{result.content[0].text[:300]}...")

            # Get forecast
            result = await session.call_tool(
                "get_forecast",
                arguments={"latitude": latitude, "longitude": longitude}
            )
            print(f"[Client {client_id}] Forecast:\n{result.content[0].text[:300]}...")


async def main():
    # Simulate multiple hosts connecting to the same server concurrently
    await asyncio.gather(
        run_client("A", state="IL", latitude=41.8781, longitude=-87.6298),  # Chicago
        run_client("B", state="CA", latitude=34.0522, longitude=-118.2437), # Los Angeles
        run_client("C", state="NY", latitude=40.7128, longitude=-74.0060),  # New York
    )


if __name__ == "__main__":
    asyncio.run(main())